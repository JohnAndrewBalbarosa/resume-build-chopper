\documentclass[11pt,a4paper]{article}
\usepackage[margin=0.7in]{geometry}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{enumitem}
\titleformat{\section}{\large\bfseries}{}{0pt}{}[\titlerule]
\setlist[itemize]{leftmargin=*,nosep,topsep=2pt}
\pagestyle{empty}

\begin{document}

\begin{center}
  {\LARGE \textbf{<< resume.contact.name | tex_escape >>}}\\[2pt]
  << resume.contact.email | tex_escape >>%
  << " $\\cdot$ " + resume.contact.phone | tex_escape if resume.contact.phone else "" >>%
  << " $\\cdot$ " + resume.contact.location | tex_escape if resume.contact.location else "" >>\\
  << resume.contact.github | tex_escape if resume.contact.github else "" >>%
  << " $\\cdot$ " + resume.contact.linkedin | tex_escape if resume.contact.linkedin else "" >>%
  << " $\\cdot$ " + resume.contact.website | tex_escape if resume.contact.website else "" >>
\end{center}

\noindent\textit{Target role:} \textbf{<< resume.role.label | tex_escape >>}

\section*{Summary}
<< resume.summary | tex_escape >>

%- if resume.skills
\section*{Skills}
<< resume.skills | join(" $\\cdot$ ") | tex_escape >>
%- endif

%- if resume.experience
\section*{Experience}
%- for x in resume.experience
\textbf{<< x.role | tex_escape >>} --- << x.company | tex_escape >>%
<< ", " + x.location | tex_escape if x.location else "" >>%
%- if x.start or x.end
 \hfill \textit{<< x.start | tex_escape >> -- << (x.end or "Present") | tex_escape >>}
%- endif
%- if x.bullets
\begin{itemize}
%- for b in x.bullets
  \item << b | tex_escape >>
%- endfor
\end{itemize}
%- endif
%- endfor
%- endif

%- if resume.projects
\section*{Projects}
%- for p in resume.projects
\textbf{<< p.name | tex_escape >>}%
<< " --- \\href{" + p.url + "}{" + p.url + "}" if p.url else "" >>\\
<< p.description | tex_escape >>
%- if p.bullets
\begin{itemize}
%- for b in p.bullets
  \item << b | tex_escape >>
%- endfor
\end{itemize}
%- endif
%- if p.tech
\textit{Tech: << p.tech | join(", ") | tex_escape >>}
%- endif
\\[4pt]
%- endfor
%- endif

%- if resume.education
\section*{Education}
%- for e in resume.education
\textbf{<< e.school | tex_escape >>}%
<< " --- " + e.degree | tex_escape if e.degree else "" >>%
<< " in " + e.field | tex_escape if e.field else "" >>%
<< " \\hfill \\textit{" + (e.start or "") + " -- " + (e.end or "") + "}" if (e.start or e.end) else "" >>
%- if e.notes
\begin{itemize}
%- for n in e.notes
  \item << n | tex_escape >>
%- endfor
\end{itemize}
%- endif
%- endfor
%- endif

%- if resume.certifications
\section*{Certifications}
\begin{itemize}
%- for c in resume.certifications
  \item \textbf{<< c.name | tex_escape >>}%
<< " --- " + c.issuer | tex_escape if c.issuer else "" >>%
<< " (" + c.date + ")" if c.date else "" >>
%- endfor
\end{itemize}
%- endif

\end{document}
